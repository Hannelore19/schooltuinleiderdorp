---
import bm1 from "../assets/bm1.jpg";
import oa261 from "../assets/oa261.jpg";
import os26 from "../assets/os26.jpg";
---

<div class="container">

  <div style="
    background:white;
    padding:30px;
    border-radius:24px;
    margin-top:30px;
  ">

    <h2>📸 Schooltuin in beeld</h2>

    <img
      src={bm1}
      alt="Burgemeester"
      style="
        width:100%;
        height:400px;
        object-fit:cover;
        border-radius:20px;
        margin-bottom:20px;
      "
    />

    <div style="
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
      gap:20px;
    ">

      <img
        src={oa261}
        alt="Open avond Schooltuin Leiderdorp"
        style="
          width:100%;
          height:250px;
          object-fit:cover;
          border-radius:20px;
        "
      />

      <img
        src={os26}
        alt="Kinderen in de schooltuin"
        style="
          width:100%;
          height:250px;
          object-fit:cover;
          border-radius:20px;
        "
      />

    </div>

    <div style="margin-top:20px;">
      <a
        href="/fotos"
        style="
          color:#2e7d32;
          font-weight:bold;
          text-decoration:none;
        "
      >
        Bekijk alle foto's →
      </a>
    </div>

  </div>

</div>
