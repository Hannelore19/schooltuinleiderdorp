---
/* Geen imports nodig */
---

<div class="container">
  <div style="background:white; padding:30px; border-radius:24px; margin-top:30px;">
    <h2>📸 Schooltuin in beeld</h2>

    <!-- Hoofdfoto -->
    <img 
      src="/schooltuinleiderdorp/assets/bm1.jpg" 
      alt="Burgemeester" 
      style="width:100%; height:400px; object-fit:cover; border-radius:20px; margin-bottom:20px;" 
    />

    <!-- Kleine foto's -->
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px;">
      <img 
        src="/schooltuinleiderdorp/assets/oa261.jpg" 
        alt="Open avond Schooltuin Leiderdorp" 
        style="width:100%; height:250px; object-fit:cover; border-radius:20px;" 
      />
      <img 
        src="/schooltuinleiderdorp/assets/os261.jpg" 
        alt="Kinderen in de schooltuin" 
        style="width:100%; height:250px; object-fit:cover; border-radius:20px;" 
      />
    </div>

    <div style="margin-top:20px;">
      <a href="/schooltuinleiderdorp/fotos" 
         style="color:#2e7d32; font-weight:bold; text-decoration:none;">
        Bekijk alle foto's →
      </a>
    </div>
  </div>
</div>
