---
import { news } from "../data/news.js";

const sorted = [...news].sort((a, b) => new Date(b.date) - new Date(a.date));
const archiveItems = sorted.slice(3); // alles behalve de 3 homepage-items
---

<div style="max-width:900px;margin:auto;padding:20px;">
  {archiveItems.map((item) => (
    <div style="background:white;padding:24px;border-radius:24px;margin-bottom:30px;">
      <h2 style="color:#1b5e20;margin:0 0 12px 0;">{item.title}</h2>

      <!-- Fotoslider -->
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide/dist/css/splide.min.css" />
      <div class="splide" id={`slider-${item.slug}`}>
        <div class="splide__track">
          <ul class="splide__list">
            {item.photos.map((photo) => (
              <li class="splide__slide">
                <img src={photo} style="width:100%;height:260px;object-fit:cover;border-radius:12px;" />
              </li>
            ))}
          </ul>
        </div>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide/dist/js/splide.min.js"></script>
      <script>
        new Splide(`#slider-${item.slug}`, {
          type: 'loop',
          perPage: 1,
          autoplay: true,
          interval: 3000,
          pauseOnHover: true,
          arrows: true,
          pagination: false
        }).mount();
      </script>

      <p style="margin-top:12px;white-space:pre-line;">{item.text}</p>
    </div>
  ))}
</div>
