---
const isHome = Astro.url.pathname === "/schooltuinleiderdorp/";
import HamburgerMenu from "./HamburgerMenu.astro";
---

{isHome && (
  <header>
    <section style="
      position:relative;
      height:420px;
      background:url('/schooltuinleiderdorp/assets/hero.jpg') center/cover no-repeat;
      border-radius:24px;
      overflow:hidden;
      margin-bottom:20px;
    ">
      <div style="position:absolute;inset:0;background:rgba(0,0,0,0.35);"></div>

      <!-- LOGO + MENU -->
      <div style="
        position:absolute;
        top:20px;
        left:20px;
        right:20px;
        display:flex;
        justify-content:space-between;
        align-items:center;
        z-index:9999;
      ">
        <a href="/schooltuinleiderdorp/" style="
          display:flex;
          align-items:center;
          gap:12px;
          text-decoration:none;
          color:white;
        ">
          <img src="/schooltuinleiderdorp/assets/logost.png" alt="Logo" style="height:50px;" />
          <span style="font-size:1.3rem;font-weight:bold;">Schooltuin Leiderdorp</span>
        </a>

        <!-- MENU KNOP -->
        <div style="
          background:#1b5e20;
          padding:8px 12px;
          border-radius:12px;
          box-shadow:0 4px 10px rgba(0,0,0,0.15);
          z-index:9999;
        ">
          <HamburgerMenu />
        </div>
      </div>

      <!-- TITEL + KNOP -->
      <div style="position:absolute;bottom:40px;left:40px;color:white;z-index:5;">
        <h1 style="font-size:2.8rem;margin:0;">Schooltuin Leiderdorp</h1>
        <p style="font-size:1.3rem;margin:10px 0 20px;">Samen zaaien, ontdekken en oogsten</p>
        <a href="/schooltuinleiderdorp/kalender" style="
          background:#1b5e20;
          padding:12px 24px;
          border-radius:12px;
          color:white;
          text-decoration:none;
          font-size:1.1rem;
        ">Bekijk de tuinkalender</a>
      </div>
    </section>
  </header>
)}
