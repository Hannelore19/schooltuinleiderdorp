---
import HamburgerMenu from "./HamburgerMenu.astro";

// HEADER AFBEELDINGEN
import headerImage from "../assets/cropped-header_meisjes_logo1.jpg";
import logo from "../assets/logost.png";
---

<div class="container">

  <div style="
    position:relative;
    border-radius:24px;
  ">

    <img
      src={headerImage}
      alt="Schooltuin Leiderdorp"
      style="
        width:100%;
        height:320px;
        object-fit:cover;
        display:block;
      "
    />

    <!-- donkere laag voor betere leesbaarheid -->
    <div style="
      position:absolute;
      inset:0;
      background:linear-gradient(
        to right,
        rgba(0,0,0,0.45),
        rgba(0,0,0,0.15)
      );
    "></div>

    <div style="
      position:absolute;
      top:20px;
      left:20px;
      right:20px;
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
    ">

      <img
        src={logo}
        alt="Logo Schooltuin Leiderdorp"
        style="
          height:80px;
          width:auto;
        "
      />

      <HamburgerMenu />

    </div>

    <div style="
      position:absolute;
      left:30px;
      bottom:30px;
      color:white;
      max-width:550px;
    ">

      <h1 style="
        margin:0;
        font-size:2.6rem;
        line-height:1.1;
        text-shadow:0 2px 10px rgba(0,0,0,0.4);
      ">
        Schooltuin Leiderdorp
      </h1>

      <p style="
        margin:12px 0 20px 0;
        font-size:1.2rem;
        text-shadow:0 2px 8px rgba(0,0,0,0.4);
      ">
        Samen zaaien, ontdekken en oogsten
      </p>

      <a
        href="/kalender"
        style="
          display:inline-block;
          background:#2e7d32;
          color:white;
          padding:12px 20px;
          border-radius:12px;
          text-decoration:none;
          font-weight:bold;
        "
      >
        Bekijk de tuinkalender
      </a>

    </div>

  </div>

</div>
