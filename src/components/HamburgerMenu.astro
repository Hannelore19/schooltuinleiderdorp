---
const base = "/schooltuinleiderdorp";
---

<details style="position:relative; z-index:999999;">
  <summary style="
    list-style:none;
    cursor:pointer;
    background:#1b5e20;
    color:white;
    padding:12px 16px;
    border-radius:12px;
    font-weight:bold;
    font-size:1.4rem;
    box-shadow:0 4px 10px rgba(0,0,0,0.15);
  ">
    ☰
  </summary>

  <div style="
    position:absolute;
    top:55px;
    right:0;
    width:220px;
    background:white;
    border:3px solid #1b5e20;
    border-radius:16px;
    box-shadow:0 10px 25px rgba(0,0,0,0.20);
    overflow:hidden;
    z-index:999999;
  ">
    <a href={`${base}/`} style="display:block; padding:14px 16px; background:#f4f8f4; border-left:6px solid #1b5e20; margin-bottom:2px; text-decoration:none; color:#333;">Home</a>
    <a href={`${base}/kalender`} style="display:block; padding:14px 16px; background:#f4f8f4; border-left:6px solid #1b5e20; margin-bottom:2px; text-decoration:none; color:#333;">Tuinkalender</a>
    <a href={`${base}/fotos`} style="display:block; padding:14px 16px; background:#f4f8f4; border-left:6px solid #1b5e20; margin-bottom:2px; text-decoration:none; color:#333;">Foto's</a>
    <a href={`${base}/nieuws`} style="display:block; padding:14px 16px; background:#f4f8f4; border-left:6px solid #1b5e20; margin-bottom:2px; text-decoration:none; color:#333;">Nieuws</a>
    <a href={`${base}/recepten`} style="display:block; padding:14px 16px; background:#f4f8f4; border-left:6px solid #1b5e20; margin-bottom:2px; text-decoration:none; color:#333;">Recepten</a>
    <a href={`${base}/gouden-wortel`} style="display:block; padding:14px 16px; background:#f4f8f4; border-left:6px solid #1b5e20; margin-bottom:2px; text-decoration:none; color:#333;">Gouden Wortel</a>
    <a href={`${base}/over-ons`} style="display:block; padding:14px 16px; background:#f4f8f4; border-left:6px solid #1b5e20; margin-bottom:2px; text-decoration:none; color:#333;">Over ons</a>
    <a href={`${base}/sponsoren`} style="display:block; padding:14px 16px; background:#f4f8f4; border-left:6px solid #1b5e20; margin-bottom:2px; text-decoration:none; color:#333;">Sponsoren</a>
    <a href={`${base}/contact`} style="display:block; padding:14px 16px; background:#f4f8f4; border-left:6px solid #1b5e20; text-decoration:none; color:#333;">Contact</a>
  </div>
</details>
