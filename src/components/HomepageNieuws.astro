---
import { news } from "../data/news.js";
import Slider from "../components/Slider.astro";

// Sorteer op datum (nieuwste eerst)
const sorted = [...news].sort((a, b) => new Date(b.date) - new Date(a.date));

// Pak de 3 nieuwste items
const homepageItems = sorted.slice(0, 3);
---

<div style="max-width:900px;margin:auto;padding:20px;">
  {homepageItems.map((item) => (
    <div style="background:white;padding:24px;border-radius:24px;margin-bottom:30px;">
      
      <h2 style="color:#1b5e20;margin:0 0 12px 0;">
        {item.title}
      </h2>

      <!-- Kleine slider -->
      <Slider photos={item.photos} height="220px" />

      <p style="margin-top:12px;white-space:pre-line;">
        {item.text}
      </p>

      <p style="margin-top:10px;">
        <a href={`/schooltuinleiderdorp/nieuws/${item.slug}`} 
           style="color:#1b5e20;font-weight:600;text-decoration:none;">
          Lees meer →
        </a>
      </p>

    </div>
  ))}
</div>
