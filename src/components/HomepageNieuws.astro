---
import { news } from "../data/news.js";

const sorted = [...news].sort((a, b) => new Date(b.date) - new Date(a.date));
const homepageItems = sorted.slice(0, 3);
---

<div style="background:white;padding:24px;border-radius:24px;width:100%;">
  {homepageItems.map((item) => (
    <div style="margin-bottom:40px;">
      <h3 style="margin:0 0 10px 0;color:#1b5e20;">{item.title}</h3>

      <!-- Fotoslider -->
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide/dist/css/splide.min.css" />
      <div class="splide" id={`slider-${item.slug}`}>
        <div class="splide__track">
          <ul class="splide__list">
            {item.photos.map((photo) => (
              <li class="splide__slide">
                <img src={photo} style="width:100%;height:220px;object-fit:cover;border-radius:12px;" />
              </li>
            ))}
          </ul>
        </div>
      </div>

      <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide/dist/js/splide.min.js"></script>
      <script>
        new Splide(`#slider-${item.slug}`, {
          type: 'loop',
          perPage: 1,
          autoplay: true,
          interval: 3000,
          pauseOnHover: true,
          arrows: true,
          pagination: false
        }).mount();
      </script>

      <p style="margin-top:12px;white-space:pre-line;">{item.text}</p>
    </div>
  ))}

  <div style="text-align:center;margin-top:20px;">
    <a href="/schooltuinleiderdorp/nieuws/" 
       style="display:inline-block;background:#1b5e20;color:white;padding:10px 22px;
              border-radius:8px;text-decoration:none;font-weight:600;">
      Meer nieuws →
    </a>
  </div>
</div>
