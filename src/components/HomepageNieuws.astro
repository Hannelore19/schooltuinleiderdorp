---
import { news } from "../data/news.js";

const sortedNews = [...news].sort(
  (a, b) => new Date(b.date) - new Date(a.date)
);

const homepageItems = sortedNews.slice(0, 3);
---

<div
  style="
    background:white;
    padding:24px;
    border-radius:24px;
    width:100%;
  "
>
  {homepageItems.map((item) => (
    <div style="margin-bottom:24px;">
      <h3 style="margin:0 0 10px 0;color:#1b5e20;">
        {item.title}
      </h3>

      <p style="margin:0 0 8px 0;">
        {item.intro}
      </p>

      <a
        href="/schooltuinleiderdorp/nieuws/"
        style="
          display:inline-block;
          color:#1b5e20;
          font-weight:600;
          text-decoration:none;
          margin-top:4px;
        "
      >
        Lees verder →
      </a>
    </div>
  ))}

  <div style="text-align:center;margin-top:10px;">
    <a
      href="/schooltuinleiderdorp/nieuws/"
      style="
        display:inline-block;
        background:#1b5e20;
        color:white;
        padding:10px 22px;
        border-radius:8px;
        text-decoration:none;
        font-weight:600;
        font-size:1rem;
      "
    >
      Meer nieuws →
    </a>
  </div>
</div>
