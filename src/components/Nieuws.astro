---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/PageHeader.astro";
/* Geen foto-imports meer */
---

<MainLayout>

  <div class="container" style="max-width:1000px;margin:auto;padding:20px;">

    <PageHeader title="Nieuws" />

    <div style="
      background:white;
      padding:35px;
      border-radius:24px;
    ">

      <!-- NIEUWSITEM 1 -->
      <h2>Seizoen 2025 van start</h2>
      <p>
        <img
          src="/schooltuinleiderdorp/assets/os26.jpg"
          alt="Start van het nieuwe tuinseizoen"
          style="width:100%;border-radius:20px;margin:0 0 20px 0;"
        />
        Het nieuwe tuinseizoen is begonnen! De leerlingen zijn enthousiast aan de
        slag gegaan met zaaien, planten en verzorgen van hun eigen tuintjes.
      </p>

      <!-- NIEUWSITEM 2 -->
      <h2>Open avond groot succes</h2>
      <p>
        <img
          src="/schooltuinleiderdorp/assets/oa261.jpg"
          alt="Open avond schooltuinen"
          style="width:100%;border-radius:20px;margin:0 0 20px 0;"
        />
        Tijdens de open avond kwamen ouders, buurtbewoners en vrijwilligers
        samen om de tuintjes te bekijken. Er was veel belangstelling en de
        kinderen vertelden trots over hun werk.
      </p>

      <!-- NIEUWSITEM 3 -->
      <h2>Leiderdorp wint Gouden Wortel</h2>
      <p>
        <img
          src="/schooltuinleiderdorp/assets/goudenwortel.jpg"
          alt="Gouden Wortel trofee"
          style="width:100%;border-radius:20px;margin:0 0 20px 0;"
        />
        Leiderdorp heeft de Gouden Wortel Publieksprijs gewonnen! Een prachtige
        erkenning voor alle vrijwilligers, leerlingen en begeleiders die zich
        inzetten voor de schooltuinen.
      </p>

    </div>

  </div>

</MainLayout>
