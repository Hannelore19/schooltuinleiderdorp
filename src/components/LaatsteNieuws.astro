---
import { news } from "../data/news.js";

// volgorde volgens jouw wens:
// nieuwste = bijenproject, daarna aardappeloogst, daarna open-avond
const ordered = [
  news.find(n => n.slug === "bijenproject"),
  news.find(n => n.slug === "aardappeloogst"),
  news.find(n => n.slug === "open-avond")
];
---

<div style="background:white; padding:30px; border-radius:24px; margin-bottom:40px;">
  <h2 style="color:#1b5e20; margin-top:0; margin-bottom:20px;">Laatste nieuws</h2>

  {ordered.map(item => (
    <div style="display:flex; gap:15px; align-items:flex-start; margin-bottom:25px;">

      <!-- kleine foto -->
      <img 
        src={item.photos[0]} 
        alt={item.title} 
        style="width:110px; height:110px; object-fit:cover; border-radius:12px;"
      />

      <!-- tekst -->
      <div>
        <h3 style="color:#1b5e20; margin:0 0 8px 0; font-size:1.2rem;">
          {item.title}
        </h3>

        <p style="margin:0; line-height:1.6; color:#555;">
          {item.intro}
        </p>
      </div>

    </div>
  ))}
</div>
