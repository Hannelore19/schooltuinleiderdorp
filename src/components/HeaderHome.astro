---
import HamburgerMenu from "./HamburgerMenu.astro";
const base = "/schooltuinleiderdorp";
---

<header style="max-width:900px; margin:0 auto 20px; position:relative;">

  <!-- HERO -->
  <section style="
    position:relative;
    height:220px;
    background:url('/schooltuinleiderdorp/assets/hero.jpg') center/cover no-repeat;
    border-radius:24px;
    overflow:hidden;
  ">

    <!-- OVERLAY -->
    <div style="position:absolute; inset:0; background:rgba(0,0,0,0.35); z-index:1;"></div>

    <!-- LOGO -->
    <div style="
      position:absolute;
      top:15px;
      left:15px;
      z-index:10;
    ">
      <a href={`${base}/`} style="text-decoration:none;">
        <img src="/schooltuinleiderdorp/assets/logost.png"
             alt="Logo Schooltuin Leiderdorp"
             style="height:60px; width:auto;" />
      </a>
    </div>

    <!-- TITEL + KNOP -->
    <div style="position:absolute; bottom:20px; left:25px; color:white; z-index:10;">
      <h1 style="font-size:2rem; margin:0;">Schooltuin Leiderdorp</h1>
      <p style="font-size:1.1rem; margin:8px 0 16px;">Samen zaaien, ontdekken en oogsten</p>

      <a href="/schooltuinleiderdorp/kalender"
        style="background:#1b5e20; padding:10px 20px; border-radius:12px; color:white; text-decoration:none; font-size:1rem;">
        Bekijk de tuinkalender
      </a>
    </div>

  </section>

  <!-- MENU (zweeft boven alles, dankzij fixed in component) -->
  <HamburgerMenu />

</header>
