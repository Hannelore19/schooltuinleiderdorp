---
import HamburgerMenu from "./HamburgerMenu.astro";
const base = "/schooltuinleiderdorp";
---

<header style="max-width:900px; margin:0 auto 20px; position:relative;">

  <!-- HERO -->
  <section style="
    position:relative;
    height:300px; /* VERKLEIND */
    background:url('/schooltuinleiderdorp/assets/hero.jpg') center/cover no-repeat;
    border-radius:24px;
    overflow:hidden;
  ">

    <!-- OVERLAY (LAGERE Z-INDEX) -->
    <div style="position:absolute; inset:0; background:rgba(0,0,0,0.35); z-index:1;"></div>

    <!-- LOGO + MENU (HOGERE Z-INDEX) -->
    <div style="
      position:absolute;
      top:20px;
      left:20px;
      right:20px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      z-index:10; /* MENU BLIJFT BOVEN ALLES */
    ">
      <a href={`${base}/`} style="text-decoration:none;">
        <img src="/schooltuinleiderdorp/assets/logost.png"
             alt="Logo Schooltuin Leiderdorp"
             style="height:70px; width:auto;" />
      </a>

      <!-- MENU -->
      <div style="z-index:999999; position:relative;">
        <HamburgerMenu />
      </div>
    </div>

    <!-- TITEL + KNOP -->
    <div style="position:absolute; bottom:30px; left:40px; color:white; z-index:10;">
      <h1 style="font-size:2.4rem; margin:0;">Schooltuin Leiderdorp</h1>
      <p style="font-size:1.2rem; margin:10px 0 20px;">Samen zaaien, ontdekken en oogsten</p>

      <a href="/schooltuinleiderdorp/kalender"
        style="background:#1b5e20; padding:12px 24px; border-radius:12px; color:white; text-decoration:none; font-size:1.1rem;">
        Bekijk de tuinkalender
      </a>
    </div>

  </section>

</header>
