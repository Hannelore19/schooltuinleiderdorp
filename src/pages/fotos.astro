---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<MainLayout>

<div class="container" style="max-width:1100px;margin:auto;padding:20px;">

  <PageHeader title="Foto's uit de schooltuin" />

  <p style="
  font-size:1.1rem;
  color:#666;
  margin-bottom:30px;
  ">
    Een indruk van het schooltuinseizoen in Leiderdorp.
  </p>

  <!-- ACTIVITEITEN -->

  <h2 style="
  color:#2e7d32;
  margin-top:30px;
  margin-bottom:20px;
  ">
    Activiteiten
  </h2>

  <div style="
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;
  margin-bottom:40px;
  ">

    <img
      src="/images/os26.jpg"
      alt="Schooltuin"
      style="width:100%;height:260px;object-fit:cover;border-radius:20px;"
    />

    <img
      src="/images/oa261.jpg"
      alt="Open avond"
      style="width:100%;height:260px;object-fit:cover;border-radius:20px;"
    />

    <img
      src="/images/bm1.jpg"
      alt="Bezoek burgemeester"
      style="width:100%;height:260px;object-fit:cover;border-radius:20px;"
    />

    <img
      src="/images/vrijwilligers.png"
      alt="Vrijwilligers"
      style="width:100%;height:260px;object-fit:cover;border-radius:20px;"
    />

  </div>

  <!-- NATUUR -->

  <h2 style="
  color:#2e7d32;
  margin-top:20px;
  margin-bottom:20px;
  ">
    Natuur en biodiversiteit
  </h2>

  <div style="
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;
  margin-bottom:40px;
  ">

    <img
      src="/images/bijopbloem.png"
      alt="Bij op bloem"
      style="width:100%;height:260px;object-fit:cover;border-radius:20px;"
    />

    <img
      src="/images/zonnebloembij.png"
      alt="Zonnebloem met bij"
      style="width:100%;height:260px;object-fit:cover;border-radius:20px;"
    />

    <img
      src="/images/boendahlia.png"
      alt="Dahlia"
      style="width:100%;height:260px;object-fit:cover;border-radius:20px;"
    />

  </div>

  <!-- OOGST -->

  <h2 style="
  color:#2e7d32;
  margin-top:20px;
  margin-bottom:20px;
  ">
    Oogst en tuinwerk
  </h2>

  <div style="
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;
  ">

    <img
      src="/images/courgette.png"
      alt="Courgette"
      style="width:100%;height:260px;object-fit:cover;border-radius:20px;"
    />

    <img
      src="/images/oogstuien.png"
      alt="Oogst uien"
      style="width:100%;height:260px;object-fit:cover;border-radius:20px;"
    />

    <img
      src="/images/tuinkruiwagen.png"
      alt="Kruiwagen"
      style="width:100%;height:260px;object-fit:cover;border-radius:20px;"
    />

  </div>

</div>

</MainLayout>