---
import Slider from "../components/Slider.astro";

// ACTIVITEITEN
import os26 from "../assets/os26.jpg";
import oa261 from "../assets/oa261.jpg";
import bm1 from "../assets/bm1.jpg";
import vrijwilligers from "../assets/vrijwilligers.png";

// NATUUR & DIEREN
import bijopbloem from "../assets/bijopbloem.png";
import zonnebloembij from "../assets/zonnebloembij.png";
import boendahlia from "../assets/boendahlia.png";

// OOGST & TUINWERK
import courgette from "../assets/courgette.png";
import oogstuien from "../assets/oogstuien.png";
import tuinkruiwagen from "../assets/tuinkruiwagen.png";

const activiteiten = [os261, oa261, bm1, vrijwilligers];
const natuur = [bijopbloem, zonnebloembij, boendahlia];
const oogst = [courgette, oogstuien, tuinkruiwagen];
---

<div style="max-width:900px;margin:auto;padding:20px;">

  <h1 style="color:#1b5e20;margin-bottom:20px;">Foto's uit de schooltuin</h1>
  <p style="color:#666;margin-bottom:30px;">
    Een vrolijk overzicht van wat we doen in de schooltuin.
  </p>

  <!-- ACTIVITEITEN -->
  <h2 style="color:#1b5e20;margin:20px 0 10px 0;">Activiteiten</h2>
  <Slider photos={activiteiten} height="300px" />

  <!-- NATUUR & DIEREN -->
  <h2 style="color:#1b5e20;margin:40px 0 10px 0;">Natuur & dieren</h2>
  <Slider photos={natuur} height="300px" />

  <!-- OOGST & TUINWERK -->
  <h2 style="color:#1b5e20;margin:40px 0 10px 0;">Oogst & tuinwerk</h2>
  <Slider photos={oogst} height="300px" />

</div>
