---
import MainLayout from "../layouts/MainLayout.astro";

// ACTIVITEITEN
const activiteiten = [
  "/schooltuinleiderdorp/assets/os261.jpg",
  "/schooltuinleiderdorp/assets/os262.jpg",
  "/schooltuinleiderdorp/assets/os263.jpg",
  "/schooltuinleiderdorp/assets/os264.jpg",
  "/schooltuinleiderdorp/assets/os265.jpg",
  "/schooltuinleiderdorp/assets/oa261.jpg",
  "/schooltuinleiderdorp/assets/bm1.jpg",
  "/schooltuinleiderdorp/assets/vrijwilligers.png"
];

// NATUUR & DIEREN
const natuur = [
  "/schooltuinleiderdorp/assets/bijopbloem.png",
  "/schooltuinleiderdorp/assets/zonnebloembij.png",
  "/schooltuinleiderdorp/assets/boendahlia.png",
  "/schooltuinleiderdorp/assets/reyneveld.png",
  "/schooltuinleiderdorp/assets/publieksprijsgw.jpg"
];

// OOGST & TUINWERK
const oogst = [
  "/schooltuinleiderdorp/assets/courgette.png",
  "/schooltuinleiderdorp/assets/oogstuien.png",
  "/schooltuinleiderdorp/assets/tuinkruiwagen.png",
  "/schooltuinleiderdorp/assets/PraxisEmmerSchepje.jpg",
  "/schooltuinleiderdorp/assets/Polderfabriek.jpg",
  "/schooltuinleiderdorp/assets/goudenwortel.jpg"
];
---

<MainLayout title="Foto’s">

  <div style="max-width:900px; margin:0 auto; padding:20px;">

    <p style="font-size:1.1rem; line-height:1.6; color:#555; margin-bottom:30px;">
      Een vrolijk overzicht van wat we doen in de schooltuin.
    </p>

    <!-- ACTIVITEITEN -->
    <h2 style="color:#1b5e20; margin:20px 0 15px;">Activiteiten</h2>
    <div style="display:grid; grid-template-columns:1fr; gap:25px;">
      {activiteiten.map((foto) => (
        <div style="background:white; padding:20px; border-radius:20px;">
          <img 
            src={foto}
            alt="Activiteit in de schooltuin"
            style="width:100%; border-radius:16px;"
          />
        </div>
      ))}
    </div>

    <!-- NATUUR & DIEREN -->
    <h2 style="color:#1b5e20; margin:40px 0 15px;">Natuur & dieren</h2>
    <div style="display:grid; grid-template-columns:1fr; gap:25px;">
      {natuur.map((foto) => (
        <div style="background:white; padding:20px; border-radius:20px;">
          <img 
            src={foto}
            alt="Natuur en dieren in de schooltuin"
            style="width:100%; border-radius:16px;"
          />
        </div>
      ))}
    </div>

    <!-- OOGST & TUINWERK -->
    <h2 style="color:#1b5e20; margin:40px 0 15px;">Oogst & tuinwerk</h2>
    <div style="display:grid; grid-template-columns:1fr; gap:25px;">
      {oogst.map((foto) => (
        <div style="background:white; padding:20px; border-radius:20px;">
          <img 
            src={foto}
            alt="Oogst en tuinwerk in de schooltuin"
            style="width:100%; border-radius:16px;"
          />
        </div>
      ))}
    </div>

  </div>

</MainLayout>
