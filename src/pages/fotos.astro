---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/PageHeader.astro";

// ACTIVITEITEN
import os26 from "../assets/os26.jpg";
import oa261 from "../assets/oa261.jpg";
import bm1 from "../assets/bm1.jpg";
import vrijwilligers from "../assets/vrijwilligers.png";

// NATUUR
import bijopbloem from "../assets/bijopbloem.png";
import zonnebloembij from "../assets/zonnebloembij.png";
import boendahlia from "../assets/boendahlia.png";

// OOGST
import courgette from "../assets/courgette.png";
import oogstuien from "../assets/oogstuien.png";
import tuinkruiwagen from "../assets/tuinkruiwagen.png";
---

<MainLayout>

<div class="container" style="max-width:1100px;margin:auto;padding:20px;">

  <PageHeader title="Foto's uit de schooltuin" />

  <p style="
  font-size:1.1rem;
  color:#666;
  margin-bottom:30px;
  ">
    Een indruk van het schooltuinseizoen in Leiderdorp.
  </p>

  <!-- ACTIVITEITEN -->

  <h2 style="color:#2e7d32;margin-top:30px;margin-bottom:20px;">
    Activiteiten
  </h2>

  <div style="
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;
  margin-bottom:40px;
  ">

    <img src={os26} alt="Schooltuin" style="width:100%;height:260px;object-fit:cover;border-radius:20px;" />
    <img src={oa261} alt="Open avond" style="width:100%;height:260px;object-fit:cover;border-radius:20px;" />
    <img src={bm1} alt="Bezoek burgemeester" style="width:100%;height:260px;object-fit:cover;border-radius:20px;" />
    <img src={vrijwilligers} alt="Vrijwilligers" style="width:100%;height:260px;object-fit:cover;border-radius:20px;" />

  </div>

  <!-- NATUUR -->

  <h2 style="color:#2e7d32;margin-top:20px;margin-bottom:20px;">
    Natuur en biodiversiteit
  </h2>

  <div style="
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;
  margin-bottom:40px;
  ">

    <img src={bijopbloem} alt="Bij op bloem" style="width:100%;height:260px;object-fit:cover;border-radius:20px;" />
    <img src={zonnebloembij} alt="Zonnebloem met bij" style="width:100%;height:260px;object-fit:cover;border-radius:20px;" />
    <img src={boendahlia} alt="Dahlia" style="width:100%;height:260px;object-fit:cover;border-radius:20px;" />

  </div>

  <!-- OOGST -->

  <h2 style="color:#2e7d32;margin-top:20px;margin-bottom:20px;">
    Oogst en tuinwerk
  </h2>

  <div style="
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;
  ">

    <img src={courgette} alt="Courgette" style="width:100%;height:260px;object-fit:cover;border-radius:20px;" />
    <img src={oogstuien} alt="Oogst uien" style="width:100%;height:260px;object-fit:cover;border-radius:20px;" />
    <img src={tuinkruiwagen} alt="Kruiwagen" style="width:100%;height:260px;object-fit:cover;border-radius:20px;" />

  </div>

</div>

</MainLayout>
