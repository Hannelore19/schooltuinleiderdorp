---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<MainLayout>

<div class="container" style="max-width:1100px;margin:auto;padding:20px;">

  <PageHeader title="📰 Nieuws" />

  <p style="
    font-size:1.1rem;
    color:#666;
    margin-bottom:30px;
  ">
    Nieuws en bijzondere momenten uit de schooltuinen van Leiderdorp.
  </p>

  <h2 style="margin-bottom:20px;">
    2026
  </h2>

  <div style="display:grid; gap:20px;">

    <div style="
      background:white;
      padding:30px;
      border-radius:24px;
    ">
      <div style="color:#666;">
        2 april 2026
      </div>

      <h3>Kinderen openen schooltuinseizoen</h3>

      <p>
        Wethouder Herman Romein opende samen met leerlingen van Het Bolwerk het nieuwe schooltuinseizoen.
      </p>

      <a
        href="https://centraalplus.nl/2026/04/02/kinderen-openen-schooltuinseizoen-in-leiderdorp-met-vieze-handen-en-frisse-lucht/"
        target="_blank"
        style="color:#2e7d32;font-weight:bold;"
      >
        Lees het artikel →
      </a>
    </div>

    <div style="
      background:white;
      padding:30px;
      border-radius:24px;
    ">
      <div style="color:#666;">
        1 juni 2026
      </div>

      <h3>Radio-interview over de schooltuinen</h3>

      <p>
        Voorzitter Joop van Huut vertelt over het belang van schooltuinonderwijs en vrijwilligerswerk.
      </p>

      <a
        href="https://centraalplus.nl/2026/06/01/woensdag-open-avond-bij-schooltuintjes-leiderdorp/"
        target="_blank"
        style="color:#2e7d32;font-weight:bold;"
      >
        Lees het artikel →
      </a>
    </div>

  </div>

</div>

</MainLayout>
