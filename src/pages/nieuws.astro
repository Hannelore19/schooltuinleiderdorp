---
import MainLayout from "../layouts/MainLayout.astro";
import { news } from "../data/news.js";

// Sorteer nieuws op datum (nieuwste eerst)
const sortedNews = [...news].sort(
  (a, b) => new Date(b.date) - new Date(a.date)
);
---

<MainLayout title="Nieuws">

  <div style="max-width:900px;margin:auto;padding:20px;">

    <h1 style="color:#1b5e20;margin-bottom:25px;">Nieuws</h1>

    {sortedNews.map((item) => (
      <div style="
        background:white;
        padding:30px;
        border-radius:24px;
        margin-bottom:25px;
      ">
        <h2 style="color:#1b5e20;margin-bottom:15px;">
          {item.title}
        </h2>

        <img
          src={`/assets/${item.photo_news}`}
          alt={item.title}
          style="width:100%;border-radius:20px;margin-bottom:20px;"
        />

        <p style="margin-bottom:10px;">
          {item.intro}
        </p>

        <a
          href={`/nieuws/${item.slug}`}
          style="color:#1b5e20;font-weight:600;text-decoration:none;"
        >
          Lees verder →
        </a>
      </div>
    ))}

  </div>

</MainLayout>
