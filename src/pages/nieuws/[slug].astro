---
import MainLayout from "../../layouts/MainLayout.astro";
import { news } from "../../data/news.js";

export function getStaticPaths() {
  return news.map((item) => ({
    params: { slug: item.slug }
  }));
}

const { slug } = Astro.params;
const item = news.find((n) => n.slug === slug);
---

<MainLayout title={item.title}>

  <div style="max-width:900px;margin:auto;padding:20px;">

    <h1 style="color:#1b5e20;margin-bottom:20px;">
      {item.title}
    </h1>

    <img
      src={`/schooltuinleiderdorp/assets/${item.photo_news}`}
      alt={item.title}
      style="width:100%;border-radius:20px;margin-bottom:20px;"
    />

    <p style="font-size:1.1rem;line-height:1.6;">
      {item.intro}
    </p>

    <p style="margin-top:30px;">
      <a href="/schooltuinleiderdorp/nieuws" style="color:#1b5e20;font-weight:600;text-decoration:none;">
        ← Terug naar nieuws
      </a>
    </p>

  </div>

</MainLayout>
