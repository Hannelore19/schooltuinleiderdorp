---
import MainLayout from "../../layouts/MainLayout.astro";
import { news } from "../../data/news.js";
import Slider from "../../components/Slider.astro";

export function getStaticPaths() {
  return news.map((item) => ({
    params: { slug: item.slug }
  }));
}

const { slug } = Astro.params;
const item = news.find((n) => n.slug === slug);
---

<MainLayout title={item.title}>
  <div style="max-width:900px;margin:auto;padding:20px;">

    <!-- Titel -->
    <h1 style="color:#1b5e20;margin-bottom:20px;">
      {item.title}
    </h1>

    <!-- Slider met alle foto's -->
    <Slider photos={item.photos} height="260px" />

    <!-- Intro -->
    <p style="font-size:1.1rem;line-height:1.6;margin-top:20px;">
      {item.intro}
    </p>

    <!-- Tekst -->
    <p style="white-space:pre-line;margin-top:20px;">
      {item.text}
    </p>

    <!-- Teruglink -->
    <p style="margin-top:30px;">
      <a href="/schooltuinleiderdorp/nieuws" 
         style="color:#1b5e20;font-weight:600;text-decoration:none;">
        ← Terug naar nieuws
      </a>
    </p>

  </div>
</MainLayout>
