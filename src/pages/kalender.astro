---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Tuinkalender">

  <div style="max-width:900px; margin:auto; padding:20px;">

    <p style="font-size:1.1rem; color:#666; margin-bottom:30px;">
      Alle activiteiten van het schooltuinseizoen overzichtelijk bij elkaar.
    </p>

    <!-- BELANGRIJKE MOMENTEN (compacte kaart) -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px;">
      <h2 style="border-bottom:2px solid #1b5e20; padding-bottom:10px; margin-top:0; margin-bottom:20px;">
        Belangrijke momenten
      </h2>

      <ul style="margin:0; padding-left:20px; line-height:1.7;">
        <li>📅 Open avond — 3 juni, 19:00–20:30</li>
        <li>🥔 Aardappeloogst — 22 t/m 26 juni</li>
        <li>🐝 Bijenproject — 29 juni t/m 10 juli</li>
        <li>🍲 Soepproject — september</li>
      </ul>
    </div>

    <!-- VOORJAAR + ZOMER SAMEN (maart t/m juli) -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px;">
      <h2 style="border-bottom:2px solid #1b5e20; padding-bottom:10px; margin-top:0; margin-bottom:25px;">
        Voorjaar (maart t/m juli)
      </h2>

      <!-- GRID VAN MAANDEN -->
      <div style="
        display:grid;
        grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
        gap:20px;
      ">

        <!-- MAART -->
        <div>
          <h3 style="margin:0 0 10px 0;">Maart</h3>
          <ul style="margin:0; padding-left:20px; line-height:1.7;">
            <li>Start Leeuwerikschool (27 maart)</li>
            <li>Paden trappen</li>
            <li>Mest strooien</li>
            <li>Aardappelen poten</li>
            <li>Sterrenkers zaaien</li>
          </ul>
        </div>

        <!-- APRIL -->
        <div>
          <h3 style="margin:0 0 10px 0;">April</h3>
          <ul style="margin:0; padding-left:20px; line-height:1.7;">
            <li>Radijs zaaien</li>
            <li>Snijbiet zaaien</li>
            <li>Wortelen zaaien</li>
            <li>Plantuien en sjalotten poten</li>
            <li>Sla en andijvie planten</li>
          </ul>
        </div>

        <!-- MEI -->
        <div>
          <h3 style="margin:0 0 10px 0;">Mei</h3>
          <ul style="margin:0; padding-left:20px; line-height:1.7;">
            <li>Bleekselderij planten</li>
            <li>Afrikaantjes planten</li>
            <li>Zonnebloemen planten</li>
            <li>Bonen leggen</li>
            <li>Oogst van radijs</li>
          </ul>
        </div>

        <!-- JUNI/JULI (oude Zomer) -->
        <div>
          <h3 style="margin:0 0 10px 0;">Juni / Juli</h3>
          <ul style="margin:0; padding-left:20px; line-height:1.7;">
            <li>3 juni: Open avond</li>
            <li>Sla en andijvie oogsten</li>
            <li>22–26 juni: aardappelen rooien</li>
            <li>Bijenproject met imker</li>
            <li>Vakantieklaar maken van de tuin</li>
          </ul>
        </div>

      </div>
    </div>

    <!-- ZOMERVAKANTIE -->
    <div style="
      background:#1b5e20;
      color:white;
      padding:40px;
      border-radius:24px;
      margin-bottom:30px;
    ">
      <h2 style="margin-top:0;">Zomervakantie</h2>
      <p style="font-size:1.2rem; margin-bottom:10px;">20 juli t/m 28 augustus</p>
      <p style="margin-bottom:10px;">
        Iedere woensdag is de tuin open van <strong>10:00 tot 12:00 uur</strong>.
      </p>
      <p style="margin-bottom:0;">
        Kinderen mogen dan onder begeleiding komen <strong>oogsten</strong> en <strong>onkruid wieden</strong>.
        Onze vrijwilligers zijn aanwezig om te helpen en vragen te beantwoorden.
      </p>
    </div>

    <!-- NAJAAR -->
    <div style="background:white; padding:30px; border-radius:24px;">
      <h2 style="border-bottom:2px solid #1b5e20; padding-bottom:10px; margin-top:0; margin-bottom:25px;">
        Najaar
      </h2>

      <ul style="margin:0; padding-left:20px; line-height:1.7;">
        <li>Tuin schoonmaken en oogsten</li>
        <li>Natuurpad</li>
        <li>Laatste woensdagmiddag: 16 september</li>
        <li>Soepproject met groenten uit de schooltuin</li>
        <li>Uitloopweek begin oktober</li>
      </ul>
    </div>

    <p style="margin-top:30px; color:#666; font-size:0.95rem;">
      Programma onder voorbehoud van weersomstandigheden, studiedagen en wijzigingen vanuit scholen.
    </p>

  </div>

</MainLayout>
