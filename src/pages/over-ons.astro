---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Over ons">
  <div style="max-width:900px;margin:auto;padding:20px;">

    <div style="background:white;padding:30px;border-radius:24px;margin-bottom:25px;">
      <h2 style="color:#1b5e20;margin-top:0;">Over de schooltuinen</h2>

      <p>
        De schooltuinen Leiderdorp worden gedragen door vrijwilligers, scholen en de gemeente.
      </p>

      <img 
        src="/schooltuinleiderdorp/assets/hero.jpg" 
        alt="Schooltuin Leiderdorp" 
        style="width:100%;border-radius:16px;margin-top:20px;"
      />

    </div>

  </div>
</MainLayout>
