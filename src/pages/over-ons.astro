---
import MainLayout from "../layouts/MainLayout.astro";
const base = "/schooltuinleiderdorp";
---

<MainLayout title="Over ons">

  <div style="max-width:900px; margin:0 auto; padding:20px;">

    <!-- FOTO -->
    <div style="margin-bottom:20px;">
      <img 
        src="/schooltuinleiderdorp/assets/vrijwilligers.png"
        alt="Vrijwilligers in de schooltuin"
        style="width:100%; border-radius:20px;"
      />
    </div>

    <!-- MISSIE -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Missie</h2>

      <p>
        Onze missie is eenvoudig: kinderen laten ervaren hoe leuk en waardevol natuur is.
      </p>
    </div>

    <!-- OVER DE TUINEN -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Over de schooltuinen</h2>

      <p>
        De schooltuinen in Leiderdorp zijn een plek waar kinderen spelenderwijs leren over natuur, groei en duurzaamheid.
        Onder begeleiding van vrijwilligers verzorgen leerlingen hun eigen stukje tuin.
      </p>

      <p>
        Ze zaaien, wieden, oogsten en ontdekken hoe planten en dieren samenleven.
      </p>
    </div>

    <!-- ORGANISATIE -->
    <div style="background:white; padding:30px; border-radius:24px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Organisatie</h2>

      <p>
        <strong>Voorzitter:</strong> J(oop).H.M. van Huut<br>
        <strong>E-mail:</strong> J.H.M.vanhuut@casema.nl<br>
        <strong>Telefoon:</strong> 071-5895032
      </p>

      <p>
        <strong>Secretariaat:</strong> Rian Knoester<br>
        <strong>E-mail:</strong> secretaris@schooltuinleiderdorp.nl<br>
        <strong>Telefoon:</strong> 06-18399981
      </p>

      <p>
        <strong>Penningmeester:</strong> Henny Verstraaten<br>
        <strong>E-mail:</strong> penningmeester@schooltuinleiderdorp.nl
      </p>

      <p>
        <strong>KvK:</strong> 28108915
      </p>
    </div>

  </div>

</MainLayout>
