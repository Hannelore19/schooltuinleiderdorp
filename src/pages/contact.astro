---
import MainLayout from "../layouts/MainLayout.astro";
const base = "/schooltuinleiderdorp";
---

<MainLayout title="Contact">

  <div style="max-width:900px; margin:0 auto; padding:20px;">

    <!-- ROUTE NAAR DE BLOEMERD -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Route naar de schooltuinen</h2>

      <p>
        De schooltuinen liggen in het recreatiegebied <strong>De Bloemerd</strong>, vlak bij
        <strong>Volkstuinvereniging De Bloemhof</strong>.
      </p>

      <p>
        <strong>Adres:</strong><br>
        Bloemerd 2-A<br>
        2353 BZ Leiderdorp
      </p>

      <p>
        Ouders kunnen de ingang het makkelijkst vinden door richting de sportvelden te rijden en
        vervolgens de borden van De Bloemhof te volgen. De schooltuinen liggen direct naast het
        volkstuincomplex.
      </p>
    </div>

    <!-- ALGEMENE INFORMATIE -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Algemene informatie</h2>

      <p>
        Voor algemene vragen, informatie of het insturen van teksten en foto’s kunt u mailen naar:
      </p>

      <p>
        <strong>E-mail:</strong><br>
        info@schooltuinleiderdorp.nl
      </p>
    </div>

    <!-- SECRETARIAAT -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Secretariaat</h2>

      <p>
        <strong>Naam:</strong> Rian Knoester<br>
        <strong>Telefoon:</strong> 06-18399981<br>
        <strong>E-mail:</strong> secretaris@schooltuinleiderdorp.nl
      </p>
    </div>

    <!-- VOORZITTER -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Voorzitter</h2>

      <p>
        <strong>Naam:</strong> J(oop).H.M. van Huut<br>
        <strong>Telefoon:</strong> 071-5895032<br>
        <strong>E-mail:</strong> J.H.M.vanhuut@casema.nl
      </p>
    </div>

    <!-- DONATIES -->
    <div style="background:white; padding:30px; border-radius:24px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Donaties</h2>

      <p>
        Financiële bijdragen voor onze organisatie kunt u overmaken op:
      </p>

      <p>
        <strong>IBAN:</strong> NL70 RABO 0108 9803 32<br>
        <strong>Ten name van:</strong> Stichting Schooltuinen Leiderdorp
      </p>
    </div>

  </div>

</MainLayout>
