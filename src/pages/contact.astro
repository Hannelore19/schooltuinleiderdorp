---
import MainLayout from "../layouts/MainLayout.astro";
const base = "/schooltuinleiderdorp";
---

<MainLayout title="Contact">

  <div style="max-width:900px; margin:0 auto; padding:20px;">

    <!-- ROUTE -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Route naar de schooltuinen</h2>

      <p>
        De schooltuinen liggen in recreatiegebied De Bloemerd, naast Volkstuinvereniging De Bloemhof.
      </p>

      <p>
        <strong>Adres:</strong><br>
        Bloemerd 2-A<br>
        2353 BZ Leiderdorp
      </p>

      <p>
        Ouders kunnen de ingang het makkelijkst vinden door richting de sportvelden te rijden en de borden van De Bloemhof te volgen.
      </p>

      <!-- ROUTEKNOP -->
      <p style="margin-top:20px;">
        <a 
          href="https://www.google.com/maps/dir/?api=1&destination=Bloemerd+2-A+Leiderdorp"
          target="_blank"
          style="
            display:inline-block;
            background:#1b5e20;
            color:white;
            padding:12px 20px;
            border-radius:12px;
            text-decoration:none;
            font-weight:bold;
          "
        >
          Route openen in Google Maps
        </a>
      </p>
    </div>

    <!-- ALGEMENE INFO -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Algemene informatie</h2>

      <p>
        Voor algemene vragen, informatie of het insturen van teksten en foto’s kunt u mailen naar:
      </p>

      <p><strong>E-mail:</strong> info@schooltuinleiderdorp.nl</p>
    </div>

    <!-- CONTACTPERSOON -->
    <div style="background:white; padding:30px; border-radius:24px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Contactpersoon</h2>

      <p>
        <strong>Naam:</strong> Rian Knoester<br>
        <strong>Telefoon:</strong> 06-18399981<br>
        <strong>E-mail:</strong> secretaris@schooltuinleiderdorp.nl
      </p>
    </div>

  </div>

</MainLayout>
