---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Contact">

  <div style="max-width:900px; margin:auto; padding:20px;">

    <!-- CONTACTGEGEVENS -->
    <div style="
      background:white;
      padding:35px;
      border-radius:24px;
      margin-bottom:30px;
    ">

      <p>
        Voor informatie, vragen of het aanleveren van foto's en teksten kunt u contact opnemen via:
      </p>

      <p>
        <strong>E-mail</strong><br>
        info@schooltuinleiderdorp.nl
      </p>

      <h2>Secretariaat</h2>
      <p>
        Rian Knoester<br>
        06-18399981<br>
        secretaris@schooltuinleiderdorp.nl
      </p>

      <h2>Voorzitter</h2>
      <p>
        J.H.M. van Huut<br>
        071-5895032<br>
        J.H.M.vanhuut@casema.nl
      </p>

    </div>

    <!-- GOOGLE MAPS ROUTE -->
    <div style="
      background:white;
      padding:20px;
      border-radius:24px;
    ">
      <h2 style="margin-top:0; color:#1b5e20;">Route naar de schooltuin</h2>

      <p style="color:#555; margin-bottom:15px;">
        De schooltuin ligt naast Volkstuinvereniging De Bloemhof, in het recreatiegebied De Bloemerd.
        Het dichtstbijzijnde adres voor navigatie is:
        <br><strong>Bloemerd 2‑A, 2353 BZ Leiderdorp</strong>.
      </p>

      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2464.046889078983!2d4.529915176744861!3d52.15839397195771!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x47c5c6d1c2c9b0d1%3A0x8e4e8f7f0f4e8c1c!2sSchooltuin%20Leiderdorp%20De%20Sterrekers!5e0!3m2!1snl!2snl!4v1710000000000"
        width="100%"
        height="350"
        style="border:0; border-radius:16px;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>

    </div>

  </div>

</MainLayout>
