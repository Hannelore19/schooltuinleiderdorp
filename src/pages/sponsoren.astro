---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Sponsoren">
  <div style="max-width:900px;margin:auto;padding:20px;">

    <div style="background:white;padding:30px;border-radius:24px;margin-bottom:25px;">
      <h2 style="color:#1b5e20;margin-top:0;">Onze sponsoren</h2>

      <p>Dank aan alle organisaties die de schooltuinen ondersteunen.</p>

      <img 
        src="/schooltuinleiderdorp/assets/logo-gemeente-leiderdorp.jpg" 
        alt="Gemeente Leiderdorp" 
        style="width:100%;max-height:300px;object-fit:contain;border-radius:16px;margin-top:20px;"
      />

      <img 
        src="/schooltuinleiderdorp/assets/fonds1818.jpg" 
        alt="Fonds 1818" 
        style="width:100%;max-height:300px;object-fit:contain;border-radius:16px;margin-top:20px;"
      />

      <img 
        src="/schooltuinleiderdorp/assets/CDA_logo_2021.jpg" 
        alt="CDA Leiderdorp" 
        style="width:100%;max-height:300px;object-fit:contain;border-radius:16px;margin-top:20px;"
      />

    </div>

  </div>
</MainLayout>
