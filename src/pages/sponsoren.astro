---
import MainLayout from "../layouts/MainLayout.astro";
const base = "/schooltuinleiderdorp";
---

<MainLayout title="Sponsoren">

  <div style="max-width:900px; margin:auto; padding:20px;">

    <!-- INTRO -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px; line-height:1.7;">
      <h2 style="color:#1b5e20; margin-top:0;">Onze sponsoren</h2>

      <p>
        De gemeente Leiderdorp ondersteunt de schooltuinen met een jaarlijkse subsidie.
        Daarnaast zijn er verschillende sponsoren die extra voorzieningen mogelijk maken.
      </p>

      <p>
        Dankzij hun steun kunnen kinderen blijven ontdekken, leren en genieten in de tuin.
      </p>
    </div>

    <!-- LOGO'S -->
    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:30px;">

      <h3 style="color:#1b5e20; margin-top:0; margin-bottom:20px;">Met dank aan:</h3>

      <div style="
        display:grid;
        grid-template-columns:repeat(auto-fit, minmax(150px, 1fr));
        gap:25px;
        align-items:center;
        justify-items:center;
      ">

        <img src="/schooltuinleiderdorp/assets/logo-gemeente-leiderdorp.jpg" alt="Gemeente Leiderdorp" style="width:120px;">
        <img src="/schooltuinleiderdorp/assets/fonds1818.jpg" alt="Fonds 1818" style="width:120px;">
        <img src="/schooltuinleiderdorp/assets/CDA_logo_2021.jpg" alt="CDA Leiderdorp" style="width:120px;">
        <img src="/schooltuinleiderdorp/assets/praxis.png" alt="Praxis Leiderdorp" style="width:120px;">
        <img src="/schooltuinleiderdorp/assets/reyneveld.png" alt="Reyneveld Leiderdorp" style="width:120px;">
        <img src="/schooltuinleiderdorp/assets/PraxisEmmerSchepje.jpg" alt="Praxis Emmer & Schepje" style="width:120px;">
        <img src="/schooltuinleiderdorp/assets/Polderfabriek.jpg" alt="Polderfabriek" style="width:120px;">

      </div>

      <p style="color:#555; margin-top:20px; line-height:1.7;">
        Praxis Leiderdorp is al sinds 2005 een trouwe sponsor van de schooltuinen.
      </p>
    </div>

    <!-- SPONSOR WORDEN -->
    <div style="background:white; padding:30px; border-radius:24px; line-height:1.7;">
      <h3 style="color:#1b5e20; margin-top:0;">Ook sponsor worden?</h3>

      <p>
        Neem contact op met de voorzitter van Stichting Schooltuinen Leiderdorp:
      </p>

      <p>
        <strong>E-mail:</strong> J.H.M.vanhuut@casema.nl<br>
        <strong>Telefoon:</strong> 071-5895032
      </p>

      <p>
        Financiële bijdragen kunt u overmaken op:<br>
        <strong>IBAN:</strong> NL70 RABO 0108 9803 32<br>
        <strong>Ten name van:</strong> Stichting Schooltuinen Leiderdorp
      </p>
    </div>

  </div>

</MainLayout>
