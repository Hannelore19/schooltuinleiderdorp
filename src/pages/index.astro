---
import MainLayout from "../layouts/MainLayout.astro";
import Nieuws from "../components/Nieuws.astro";
---

<MainLayout>

  <!-- DRIE BLOKKEN -->
  <section style="
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:20px;
    margin:40px auto;
    max-width:1000px;
  ">
    <div style="background:#e8f3e8;padding:24px;border-radius:16px;">
      <h2 style="margin-top:0;">Nieuws</h2>
      <p>Lees de laatste updates van de tuin.</p>
      <a href="/schooltuinleiderdorp/nieuws" style="color:#1b5e20;font-weight:bold;">Bekijk nieuws →</a>
    </div>

    <div style="background:#e8f3e8;padding:24px;border-radius:16px;">
      <h2 style="margin-top:0;">Kalender</h2>
      <p>Bekijk wat we deze week gaan doen.</p>
      <a href="/schooltuinleiderdorp/kalender" style="color:#1b5e20;font-weight:bold;">Bekijk kalender →</a>
    </div>

    <div style="background:#e8f3e8;padding:24px;border-radius:16px;">
      <h2 style="margin-top:0;">Foto’s</h2>
      <p>Kijk mee in de tuin door het jaar heen.</p>
      <a href="/schooltuinleiderdorp/fotos" style="color:#1b5e20;font-weight:bold;">Bekijk foto’s →</a>
    </div>
  </section>

  <!-- FOTO SLIDER -->
  <section style="max-width:1000px;margin:40px auto;">
    <h2>Foto’s uit de tuin</h2>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css" />

    <div id="image-slider" class="splide" style="margin-top:20px;">
      <div class="splide__track">
        <ul class="splide__list">
          <li class="splide__slide">
            <img src="/schooltuinleiderdorp/assets/foto1.jpg" style="width:100%;border-radius:16px;" />
          </li>
          <li class="splide__slide">
            <img src="/schooltuinleiderdorp/assets/foto2.jpg" style="width:100%;border-radius:16px;" />
          </li>
          <li class="splide__slide">
            <img src="/schooltuinleiderdorp/assets/foto3.jpg" style="width:100%;border-radius:16px;" />
          </li>
        </ul>
      </div>
    </div>

    <style>
      /* Pijltjes mooi op de foto */
      .splide__arrow {
        background: rgba(0, 0, 0, 0.4);
        width: 40px;
        height: 40px;
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
      }
      .splide__arrow svg {
        fill: white;
      }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js"></script>
    <script>
      new Splide('#image-slider', {
        type: 'loop',
        perPage: 1,
        autoplay: true,
        interval: 3000,
        pauseOnHover: true,
        arrows: true,
        pagination: false
      }).mount();
    </script>
  </section>

  <!-- LAATSTE NIEUWS -->
  <section style="max-width:1000px;margin:40px auto;">
    <h2>Laatste nieuws</h2>
    <Nieuws />
  </section>

</MainLayout>
