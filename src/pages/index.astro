---
import MainLayout from "../layouts/MainLayout.astro";
import InfoCards from "../components/InfoCards.astro";
import DezeWeek from "../components/DezeWeek.astro";
import HomepageNieuws from "../components/HomepageNieuws.astro";
---

<MainLayout>

  <!-- INFOCARDS -->
  <section style="max-width:1000px; margin:20px auto 30px;">
    <InfoCards />
  </section>

  <!-- DEZE WEEK -->
  <section style="max-width:1000px; margin:20px auto 40px;">
    <DezeWeek />
  </section>

  <!-- LAATSTE NIEUWS -->
  <section style="max-width:1000px; margin:20px auto 40px;">
    <h2 style="margin-bottom:15px;">Laatste nieuws</h2>
    <HomepageNieuws />
  </section>

</MainLayout>
