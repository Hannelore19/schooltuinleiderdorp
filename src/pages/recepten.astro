---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<MainLayout>

<div class="container" style="max-width:1100px;margin:auto;padding:20px;">

  <PageHeader title="Recepten uit de schooltuin" />

  <div style="
    background:white;
    padding:30px;
    border-radius:24px;
    margin-bottom:25px;
  ">

    <p>
      In de schooltuinen worden ieder jaar groenten, kruiden en bloemen
      gekweekt. Met de oogst kun je thuis heerlijke gerechten maken.
    </p>

    <p>
      Op deze pagina verzamelen we eenvoudige recepten die passen bij de
      groenten uit de schooltuin.
    </p>

  </div>

  <div style="
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:20px;
  ">

    <div style="
      background:white;
      padding:25px;
      border-radius:20px;
      border-top:5px solid #2e7d32;
    ">
      <h3>Aardappelsoep</h3>
      <p>
        Een eenvoudige soep met aardappelen, ui en kruiden uit de tuin.
      </p>
    </div>

    <div style="
      background:white;
      padding:25px;
      border-radius:20px;
      border-top:5px solid #2e7d32;
    ">
      <h3>Courgettesoep</h3>
      <p>
        Een romige soep van verse courgettes uit de schooltuin.
      </p>
    </div>

    <div style="
      background:white;
      padding:25px;
      border-radius:20px;
      border-top:5px solid #2e7d32;
    ">
      <h3>Frisse salade</h3>
      <p>
        Met sla, radijs en kruiden uit eigen tuin.
      </p>
    </div>

    <div style="
      background:white;
      padding:25px;
      border-radius:20px;
      border-top:5px solid #2e7d32;
    ">
      <h3>Schooltuinsoep</h3>
      <p>
        Een groentesoep met wisselende ingrediënten uit het seizoen.
      </p>
    </div>

  </div>

  <div style="
    background:#f7faf7;
    padding:30px;
    border-radius:24px;
    margin-top:25px;
    border-left:6px solid #2e7d32;
  ">

    <h2>Heb je een leuk recept?</h2>

    <p>
      Recepten van leerlingen, ouders en vrijwilligers zijn van harte welkom.
    </p>

  </div>

</div>

</MainLayout>
