---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Gouden Wortel Publieksprijs 2025">
  <div style="max-width:900px; margin:auto; padding:20px;">

    <div style="background:white; padding:30px; border-radius:24px; margin-bottom:25px;">
      <h2 style="color:#1b5e20; margin-bottom:20px;">Gouden Wortel Publieksprijs 2025</h2>

      <img 
        src="/schooltuinleiderdorp/assets/publieksprijsgw.jpg" 
        alt="Uitreiking Gouden Wortel Publieksprijs" 
        style="width:100%; border-radius:16px; margin-bottom:20px;" 
      />

      <p>
        In 2025 ontving de Schooltuinen Leiderdorp de 
        <strong>Gouden Wortel Publieksprijs</strong>.
      </p>

      <p>
        Leiderdorp kreeg maar liefst <strong>61% van alle stemmen</strong>.
      </p>

      <p>
        De prijs werd uitgereikt aan wethouders 
        <strong>Gebke van Gaal</strong> en <strong>Herman Romeijn</strong>.
      </p>

      <p>
        De schooltuinen worden mogelijk gemaakt door een grote groep vrijwilligers.
      </p>
    </div>

    <div style="background:#f7faf7; padding:25px; border-radius:24px; border-left:6px solid #1b5e20;">
      <p style="margin:0;">
        Heeft u nieuws of foto's voor de website?  
        Mail naar <strong>info@schooltuinleiderdorp.nl</strong>.
      </p>
    </div>

  </div>
</MainLayout>
