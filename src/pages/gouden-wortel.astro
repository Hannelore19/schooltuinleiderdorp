---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/PageHeader.astro";
---

<MainLayout>

<div class="container" style="max-width:1000px;margin:auto;padding:20px;">

  <PageHeader title="🏆 Gouden Wortel Publieksprijs 2025" />

  <img
    src="/images/publieksprijsgw.jpg"
    alt="Uitreiking Gouden Wortel Publieksprijs"
    style="
    width:100%;
    border-radius:24px;
    margin-bottom:20px;
    "
  />

  <p style="
  color:#666;
  font-size:0.95rem;
  margin-bottom:30px;
  ">
    Wethouders Gebke van Gaal en Herman Romeijn ontvangen de
    Gouden Wortel Publieksprijs namens Leiderdorp.
  </p>

  <div style="
  background:white;
  padding:35px;
  border-radius:24px;
  ">

    <h2>Publieksprijs voor Leiderdorp</h2>

    <p>
      Leiderdorp kreeg in 2025 de meeste stemmen van het publiek
      bij de verkiezing van de Gouden Wortel.
    </p>

    <p>
      Met maar liefst <strong>61% van alle stemmen</strong>
      won Leiderdorp overtuigend de landelijke publieksprijs
      voor schooltuinonderwijs.
    </p>

    <p>
      Op vrijdag 23 mei ontvingen wethouders Gebke van Gaal en
      Herman Romeijn een oorkonde en een grote worteltaart.
    </p>

    <p>
      De prijs is een initiatief van de Alliantie Schooltuinen
      en het programma Jong Leren Eten.
    </p>

    <p>
      De onderscheiding is een waardering voor de inzet van
      vrijwilligers, scholen, gemeente en leerlingen die zich
      ieder jaar inzetten voor de schooltuinen van Leiderdorp.
    </p>

  </div>

  <div style="
  background:white;
  padding:35px;
  border-radius:24px;
  margin-top:25px;
  ">

    <img
      src="/images/goudenwortel.jpg"
      alt="Gouden Wortel"
      style="
      width:100%;
      border-radius:20px;
      "
    />

  </div>

</div>

</MainLayout>