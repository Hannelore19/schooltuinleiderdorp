---
import MainLayout from "../layouts/MainLayout.astro";
import PageHeader from "../components/PageHeader.astro";

// FOTO'S
import publieksprijs from "../assets/publieksprijsgw.jpg";
import goudenwortel from "../assets/goudenwortel.jpg";
---

<MainLayout>

<div class="container" style="max-width:1000px;margin:auto;padding:20px;">

  <PageHeader title="🏆 Gouden Wortel Publieksprijs 2025" />

  <img
    src={publieksprijs}
    alt="Uitreiking Gouden Wortel Publieksprijs"
    style="
      width:100%;
      border-radius:24px;
      margin-bottom:20px;
    "
  />

  <p style="
    color:#666;
    font-size:0.95rem;
    margin-bottom:30px;
  ">
    Wethouders Gebke van Gaal en Herman Romeijn ontvangen de
    Gouden Wortel Publieksprijs namens Leiderdorp.
  </p>

  <div style="
    background:white;
    padding:35px;
    border-radius:24px;
  ">

    <h2>Publieksprijs voor Leiderdorp</h2>

    <p>
      Leiderdorp kreeg in 2025 de meeste