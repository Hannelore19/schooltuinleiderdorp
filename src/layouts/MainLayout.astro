---
import "../styles/global.css";
import Header from "../components/Header.astro";
import PageHeader from "../components/PageHeader.astro";
import Footer from "../components/Footer.astro";

const isHome = Astro.url.pathname === "/schooltuinleiderdorp/";
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Schooltuin Leiderdorp</title>

    <link rel="icon" type="image/x-icon" href="/schooltuinleiderdorp/assets/favicon.ico" />
  </head>

  <body style="margin:0; padding:0; background:#f5f5f5;">

    <!-- App-container -->
    <div style="
      max-width:900px;
      margin:0 auto;
      padding:20px;
    ">

      <!-- Automatische header-keuze -->
      {isHome ? (
        <Header />
      ) : (
        <PageHeader title={Astro.props.title || ""} />
      )}

      <!-- Content -->
      <main style="margin-top:20px;">
        <slot />
      </main>

      <!-- Footer op alle pagina's -->
      <Footer />

    </div>

  </body>
</html>
