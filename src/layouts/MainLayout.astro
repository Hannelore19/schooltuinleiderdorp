---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Schooltuin Leiderdorp</title>

    <link rel="icon" type="image/x-icon" href="/schooltuinleiderdorp/assets/favicon.ico" />
  </head>

  <body style="margin:0; padding:0; background:#f5f5f5;">

    <!-- App-container -->
    <div style="
      max-width:900px;
      margin:0 auto;
      padding:20px;
    ">

      <!-- Header (home of pageheader afhankelijk van pagina) -->
      <Header />

      <!-- Content -->
      <main style="margin-top:20px;">
        <slot />
      </main>

      <!-- Footer -->
      <Footer />

    </div>

  </body>
</html>
